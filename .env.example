# Daily Video Reporter — environment configuration.
# Copy to ".env" and fill in. Real env vars always override these.

# --- Git extraction (Story 1.2) ---
# Repository to report on (defaults to this project's own repo).
REPORTER_TARGET_REPO=/Users/thienuser/Documents/report-daily
# Commit author to match (case-insensitive).
REPORTER_GIT_AUTHOR=Thienpham
# git --since window. Use "today" for production; widen for testing.
REPORTER_SINCE=today
REPORTER_NAME=Thienpham

# --- OmniVoice TTS (Story 1.3) ---
# REQUIRED for voice cloning: a short, clean WAV of the target voice + its transcript.
REPORTER_REF_AUDIO=/Users/thienuser/Documents/report-daily/ref/reference.wav
REPORTER_REF_TEXT=Xin chào, đây là giọng đọc tham chiếu dùng để nhân bản giọng nói cho báo cáo công việc hằng ngày.
# auto | mps | cpu | cuda
REPORTER_TTS_DEVICE=auto
OMNIVOICE_MODEL=k2-fsa/OmniVoice

# --- DevZone (Story 1.5) — falls back to values parsed from project-context.md ---
DEVZONE_BASE_URL=https://api.devzone.vietnix.dev
DEVZONE_PROJECT_ID=wozONU8U79scVlep
DEVZONE_API_KEY=dc9343c5cea6f6bbd0957d17bd49022d
